# ── Backend port (match this in frontend/.env REACT_APP_API_URL) ──
# PORT=5500

# # ── CRM Chat DB ───────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=yourpassword
# DB_NAME=crm_chat
CLIENT_URL=https://chat.pidmetric.com
# CLIENT_URL=http://localhost:3000

# ── Your existing CRM DB (for auto-importing campaigns) ────────
# Leave CRM_DB_HOST blank/unset to disable
# CRM_DB_HOST=localhost
# CRM_DB_PORT=3306
# CRM_DB_USER=root
# CRM_DB_PASSWORD=yourpassword
# CRM_DB_NAME=your_existing_crm_db
# CRM_CAMPAIGN_TABLE=campaigns

# # ── Auth / Security ───────────────────────────────────────────
# JWT_SECRET=change-this-to-a-long-random-string-in-production
# ENCRYPTION_KEY=32-chars-exactly-change-this-now!

# # ── CORS: URL your React frontend runs on ─────────────────────
# CLIENT_URL=http://localhost:3000

# # ── File uploads ──────────────────────────────────────────────
# MAX_FILE_SIZE=52428800
# UPLOAD_DIR=uploads
